# Data — our parquets + HINT benchmark (symlink) + materialized canonical
# datasets. Large / immutable / regenerable; never committed.
data/

# Pulled-in HINT subtree: code is tracked, big artifacts are not.
hint/.venv/
hint/data/*.pkl
hint/data/*.csv
hint/save_model/*.ckpt
hint/results/
hint/figure/

# Pulled-in ChemAP subtree: code is tracked, venv / checkpoints / big data are not.
chemap/.venv*/
chemap/model/**/*.pt
chemap/candidate_detail.parquet
chemap/results/

# Run outputs.
runs/
runs_old/
runs_final/

# Python / uv.
.venv/
__pycache__/
*.pyc
.pytest_cache/
uv.lock
